{
  "name": "codex-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @codex-app/todo run dev",
    "dev:api": "pnpm --filter @codex-app/api run dev",
    "build": "pnpm --recursive --if-present run build",
    "knip": "knip",
    "preview": "pnpm --filter @codex-app/todo run preview",
    "typecheck": "tsc --build tsconfig.json",
    "lint": "oxlint apps packages --deny-warnings --config .oxlintrc.json",
    "format": "oxfmt -c .oxfmtrc.json . --write",
    "test": "pnpm --recursive --if-present run test"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jiti": "2.7.0",
    "knip": "6.27.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^7.0.2001",
    "tsx": "4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@11.15.1"
}
